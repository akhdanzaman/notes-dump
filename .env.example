# Google OAuth client used for optional Google sign-in / Drive appData backup.
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# Google Sheets service account used by the server-side spreadsheet proxy.
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace-with-private-key\n-----END PRIVATE KEY-----\n"

# Required in production: comma-separated spreadsheet IDs the service account proxy may access.
SERVICE_ACCOUNT_ALLOWED_SPREADSHEET_IDS=your-google-spreadsheet-id

# Required in production if GOOGLE_CLIENT_SECRET is not available to the auth URL/exchange routes.
# Use a long random value, e.g. `openssl rand -base64 48`.
OAUTH_STATE_SECRET=replace-with-long-random-secret

# Required in production if the service-account private key is not present in env.
# Use a long random value, e.g. `openssl rand -base64 48`.
SERVICE_ACCOUNT_SESSION_SECRET=replace-with-long-random-secret

# Optional: comma-separated additional app origins allowed for OAuth/service-account browser requests.
# Example: https://arkaiv.example.com,https://preview.example.com
OAUTH_ALLOWED_ORIGINS=
SERVICE_ACCOUNT_ALLOWED_ORIGINS=
